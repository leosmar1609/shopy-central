# Asaas Configuration (sandbox/homolog ou produção)
# Cole a chave SEM o "$" do início (ex: chave "$aact_prod_xxx" do painel do Asaas
# vira ASAAS_API_KEY=aact_prod_xxx aqui) — o "$" é adicionado automaticamente pelo
# código, porque o dotenv-expand do Vite apaga esse caractere se ele vier no .env.
ASAAS_API_KEY=aact_prod_ou_hmlg_sua_api_key_aqui
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Application URLs
VITE_APP_URL=http://localhost:5173

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=lumiere

# JWT Secret (obrigatório — a aplicação falha ao iniciar sem esta variável)
PJWT_SECRET=uma_string_aleatoria_longa_aqui

# E-mail transacional (Resend) — usado para confirmação de conta e redefinição de senha.
# Sem RESEND_API_KEY configurado, o cadastro ainda funciona mas o e-mail de confirmação
# não é enviado (o usuário pode pedir reenvio depois na tela de login).
# IMPORTANTE: "onboarding@resend.dev" só entrega pro e-mail do dono da conta Resend —
# pra enviar pra qualquer cliente, verifique seu domínio em resend.com/domains e use
# um remetente desse domínio aqui (ex: "Lumière <contato@seudominio.com.br>").
RESEND_API_KEY=sua_resend_api_key_aqui
EMAIL_FROM="Lumière <onboarding@resend.dev>"

# Rastreio de pedidos (17TRACK) — usado em Minha Conta > Pedidos para mostrar a
# localização do pacote. Sem isso, o código de rastreio ainda é salvo normalmente,
# só não aparecem os eventos/localização (fica "aguardando atualização").
TRACK17_API_KEY=sua_17track_api_key_aqui

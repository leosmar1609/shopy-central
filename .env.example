# Asaas Configuration (sandbox/homolog)
ASAAS_API_KEY=sua_api_key_aqui
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Application URLs
VITE_APP_URL=http://localhost:5173

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=lumiere

# JWT Secret (obrigatório — a aplicação falha ao iniciar sem esta variável)
PJWT_SECRET=uma_string_aleatoria_longa_aqui

# E-mail transacional (Resend) — usado para confirmação de conta e redefinição de senha.
# Sem RESEND_API_KEY configurado, o cadastro ainda funciona mas o e-mail de confirmação
# não é enviado (o usuário pode pedir reenvio depois na tela de login).
RESEND_API_KEY=sua_resend_api_key_aqui
EMAIL_FROM="Lumière <onboarding@resend.dev>"
